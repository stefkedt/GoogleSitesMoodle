{
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**", "exports/**"],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "google-sites-to-moodle",
          "region": "europe-west1"
        }
      }
    ]
  }
}
