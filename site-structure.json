      {
        "title": "Planning",
        "url": "https://sites.google.com/cvoantwerpen.org/gooddesign/planning",
        "blocks": [
          {
            "type": "heading",
            "level": 1,
            "text": "PLANNING"
          },
          {
            "type": "heading",
            "level": 2,
            "text": "DESIGNBRIEF"
          },
          {
            "type": "paragraph",
            "text": "Gebruik voor grotere projecten een design brief. Maak schetsen van je ideeën, zet zoveel mogelijk op papier."
          },
          {
            "type": "heading",
            "level": 3,
            "text": "“Plans are of little importance, but planning is essential.”"
          },
          {
            "type": "heading",
            "level": 3,
            "text": "Winston Churchill"
          }
        ],
        "children": []
      },
